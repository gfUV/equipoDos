<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.wt2dadmuvy.spinbot.view.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.wt2dadmuvy.spinbot.view.home.HomeFragment"
        android:label="Home Principal"
        tools:layout="@layout/fragment_home">

        <!-- Acción para navegar al Fragment de Retos (HU 6 - Natalia) -->
        <action
            android:id="@+id/action_homeFragment_to_challengesFragment"
            app:destination="@id/challengesFragment" />
    </fragment>

    <!--
        Pantalla de Retos - HU 6.0 (Natalia)
        Se navega desde el botón "Retos" de la toolbar del home.
        Al presionar la flecha atrás dentro de este fragment, el NavController
        regresa automáticamente al homeFragment (navigateUp).
    -->
    <fragment
        android:id="@+id/challengesFragment"
        android:name="com.wt2dadmuvy.spinbot.view.challenges.ChallengesFragment"
        android:label="Retos"
        tools:layout="@layout/fragment_challenges" />

</navigation>
