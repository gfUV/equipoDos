<?xml version="1.0" encoding="utf-8"?>
<!--
    Pantalla de Agregar y Listar Retos - HU 6.0
    Criterio 2: Fondo de color gris oscuro (#2A2A2A)
    Criterio 3: Toolbar personalizada con título "Retos" y botón flecha atrás
    Criterio 4 y 5: RecyclerView con lista de retos y scroll automático
    Criterio 8: Botón flotante (FAB) naranja para agregar nuevo reto
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF2A2A2A">

    <!--
        TOOLBAR PERSONALIZADA - HU 6 Criterio 3
        Misma apariencia que la toolbar del home (fondo negro, bordes redondeados)
        pero con título "Retos" y botón de regreso en lugar de los 5 íconos.
    -->
    <LinearLayout
        android:id="@+id/challengesToolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón flecha atrás: al dar click regresa al home y restaura el audio (Criterio 3) -->
        <ImageButton
            android:id="@+id/btnBackChallenges"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ripple_orange"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Volver al home"
            android:padding="8dp" />

        <!-- Título "Retos" centrado en la toolbar -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Retos"
            android:textColor="@color/orange"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!--
            Vista invisible para equilibrar el título visualmente
            (ocupa el mismo espacio que el botón de la izquierda)
        -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <!--
        LISTA DE RETOS - HU 6 Criterio 4 y 5
        RecyclerView con scroll automático cuando la lista supera el tamaño de la pantalla.
        Los ítems se muestran de más nuevo a más antiguo (ORDER BY id DESC en el DAO).
        El padding inferior evita que el último ítem quede oculto detrás del FAB.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChallenges"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/challengesToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        BOTÓN FLOTANTE (FAB) - HU 6 Criterio 8
        Color naranja. Al dar click lanza el cuadro de diálogo de HU 7 (Jonatan).
    -->
    <!-- FAB circular naranja — forzar forma circular perfecta con shapeAppearanceOverlay -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddChallenge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Agregar nuevo reto"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/orange"
        app:tint="@color/white"
        app:fabSize="normal"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
