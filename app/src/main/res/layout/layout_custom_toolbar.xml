<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@drawable/bg_custom_toolbar"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:weightSum="5">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnCalificar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/ripple_orange"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Calificar"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/star"
        app:tint="@color/orange" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnAudio"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/ripple_orange"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Audio"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/volume_up"
        app:tint="@color/orange" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnInstrucciones"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/ripple_orange"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Instrucciones"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/sports"
        app:tint="@color/orange" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnRetos"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/ripple_orange"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Retos"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/add_circle"
        app:tint="@color/orange" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnCompartir"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/ripple_orange"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Compartir"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/share"
        app:tint="@color/orange" />

</LinearLayout>