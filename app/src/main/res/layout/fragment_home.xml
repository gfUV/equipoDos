<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wood_floor"
    android:padding="24dp"
    tools:context=".view.home.HomeFragment">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/layout_custom_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/bottleGlow"
        android:layout_width="310dp"
        android:layout_height="310dp"
        android:alpha="0.55"
        android:background="@drawable/bg_bottle_glow"
        app:layout_constraintBottom_toTopOf="@id/btnPressMe"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customToolbar"
        app:layout_constraintVertical_bias="0.48" />

    <ImageView
        android:id="@+id/imgBottle"
        android:layout_width="155dp"
        android:layout_height="320dp"
        android:contentDescription="@string/bottle_content_description"
        android:rotation="-24"
        android:src="@drawable/ic_bottle_home"
        app:layout_constraintBottom_toBottomOf="@id/bottleGlow"
        app:layout_constraintEnd_toEndOf="@id/bottleGlow"
        app:layout_constraintStart_toStartOf="@id/bottleGlow"
        app:layout_constraintTop_toTopOf="@id/bottleGlow" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_countdown"
        android:gravity="center"
        android:shadowColor="@color/game_black"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="4"
        android:text="3"
        android:textColor="@color/game_orange"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imgBottle"
        app:layout_constraintEnd_toEndOf="@id/imgBottle"
        app:layout_constraintStart_toStartOf="@id/imgBottle"
        app:layout_constraintTop_toTopOf="@id/imgBottle" />

    <View
        android:id="@+id/pressMeShadow"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginBottom="-26dp"
        android:background="@drawable/bg_press_me_shadow"
        app:layout_constraintBottom_toTopOf="@id/btnPressMe"
        app:layout_constraintEnd_toEndOf="@id/btnPressMe"
        app:layout_constraintStart_toStartOf="@id/btnPressMe" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPressMe"
        android:layout_width="190dp"
        android:layout_height="56dp"
        android:layout_marginBottom="42dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/press_me"
        android:textAllCaps="false"
        android:textColor="@color/game_black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/game_orange"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="@color/game_orange_light" />

</androidx.constraintlayout.widget.ConstraintLayout>