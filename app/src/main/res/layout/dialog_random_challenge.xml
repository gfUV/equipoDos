<?xml version="1.0" encoding="utf-8"?>
<!--
    HU 12 - Mostrar reto aleatorio (criterios 1 al 4).
    Ajuste visual: el círculo del Pokémon queda superpuesto al borde superior,
    pero el texto inicia más abajo para no quedar tapado.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/containerRandomChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="54dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_random_challenge_dialog"
        android:gravity="center_horizontal"
        android:minHeight="250dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="104dp"
        android:paddingEnd="24dp"
        android:paddingBottom="76dp">

        <TextView
            android:id="@+id/tvRandomChallenge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/random_challenge_placeholder"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/containerPokemonCircle"
        android:layout_width="108dp"
        android:layout_height="108dp"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/bg_pokemon_circle"
        android:elevation="8dp"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgPokemon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:contentDescription="@string/pokemon_random_image"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_bottle_home" />

        <ProgressBar
            android:id="@+id/pbPokemon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminate="true" />

    </FrameLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCloseRandomChallenge"
        android:layout_width="140dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|center_horizontal"
        android:background="@drawable/bg_random_close_button"
        android:gravity="center"
        android:text="@string/close"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

</FrameLayout>
